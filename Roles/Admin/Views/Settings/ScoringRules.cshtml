@{
    ViewData["Title"] = "Scoring Engine Weights";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Scoring Engine Configuration</h1>
        <p class="text-muted">Adjust the credit risk weight parameters. Preview impact updates live.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="fw-bold m-0">Risk Parameter Weights</h5>
                <span class="text-muted small">Total allocation must equal <strong>100%</strong>.</span>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1"><span class="fw-semibold small text-dark">Bureau Score (CIBIL)</span><span class="fw-bold text-primary small">35%</span></div>
                    <div class="progress" style="height: 8px;"><div class="progress-bar bg-primary" style="width: 70%;"></div></div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1"><span class="fw-semibold small text-dark">Debt-to-Income Ratio</span><span class="fw-bold text-primary small">25%</span></div>
                    <div class="progress" style="height: 8px;"><div class="progress-bar bg-primary" style="width: 50%;"></div></div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1"><span class="fw-semibold small text-dark">Credit History Age</span><span class="fw-bold text-primary small">15%</span></div>
                    <div class="progress" style="height: 8px;"><div class="progress-bar bg-primary" style="width: 30%;"></div></div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1"><span class="fw-semibold small text-dark">Repayment Consistency</span><span class="fw-bold text-primary small">15%</span></div>
                    <div class="progress" style="height: 8px;"><div class="progress-bar bg-primary" style="width: 30%;"></div></div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1"><span class="fw-semibold small text-dark">Credit Utilization Rate</span><span class="fw-bold text-primary small">10%</span></div>
                    <div class="progress" style="height: 8px;"><div class="progress-bar bg-primary" style="width: 20%;"></div></div>
                </div>
                <div class="alert alert-success border-0 mt-4 p-3" style="border-radius: var(--radius-md);">
                    <div class="d-flex justify-content-between"><span class="fw-semibold">Total Weight Allocation</span><span class="fw-bold">100%</span></div>
                    <div class="progress mt-2" style="height: 6px;"><div class="progress-bar bg-success" style="width: 100%;"></div></div>
                </div>
                <a href="/Dashboard" class="btn btn-primary px-4 py-2 mt-3"><i class="fa-solid fa-floppy-disk me-2"></i> Save Configuration</a>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="fw-bold m-0">Live Impact Preview</h5>
                <span class="text-muted small">Score for sample applicant (CIBIL 785, DTI 32%).</span>
            </div>
            <div class="card-body">
                <div class="text-center py-3">
                    <div class="display-6 fw-bold text-success">810</div>
                    <div class="text-muted small mt-1">Computed Credit Score</div>
                    <span class="badge bg-success mt-2 px-3 py-2">Excellent (Tier A)</span>
                </div>
                <hr />
                <ul class="list-group list-group-flush" style="font-size: 0.8rem;">
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between"><span class="text-muted">Bureau Score (CIBIL)</span><span class="fw-semibold">+275 pts</span></li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between"><span class="text-muted">Debt-to-Income Ratio</span><span class="fw-semibold">+210 pts</span></li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between"><span class="text-muted">Credit History Age</span><span class="fw-semibold">+135 pts</span></li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between"><span class="text-muted">Repayment Consistency</span><span class="fw-semibold">+120 pts</span></li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between"><span class="text-muted">Credit Utilization Rate</span><span class="fw-semibold">+70 pts</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>
