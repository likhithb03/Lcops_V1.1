                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 48px; height: 48px; background-color: #1A56DB;"><i class="fa-solid fa-house"></i></div>
                    <span class="badge-status badge-status-approved">Active</span>
                </div>
                <h5 class="fw-bold text-dark mb-2">Home Purchase Loan</h5>
                <ul class="list-unstyled text-muted small mb-3">
                    <li class="mb-1"><i class="fa-solid fa-percent me-2 text-primary opacity-50"></i> Interest: <strong>8.5% – 10.0%</strong></li>
                    <li class="mb-1"><i class="fa-solid fa-sack-dollar me-2 text-primary opacity-50"></i> Max: <strong>₹ 5 Crore</strong></li>
                    <li><i class="fa-solid fa-clock me-2 text-primary opacity-50"></i> Tenure: <strong>10 – 30 Years</strong></li>
                </ul>
                <a href="/Product/Details/1" class="btn btn-outline-primary btn-sm w-100">View Details</a>
