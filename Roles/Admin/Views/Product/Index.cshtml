@{
    ViewData["Title"] = "Loan Products";
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Loan Product Catalog</h1>
        <p class="text-muted mb-0">Manage all available loan product offerings and configurations.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <a href="/Product/Create" class="btn btn-primary px-4 py-2" style="border-radius: var(--radius-md);"><i class="fa-solid fa-plus me-2"></i> Create New Product</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 card-hover">
