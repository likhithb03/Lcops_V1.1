@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Reports & Analytics</h1>
        <p class="text-muted mb-0">Business intelligence dashboard for loan origination metrics.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <div class="d-flex gap-2 justify-content-sm-end">
            <a href="/Reports" class="btn btn-outline-secondary btn-sm px-3"><i class="fa-solid fa-print me-2"></i> Print Report</a>
            <a href="/Reports" class="btn btn-outline-primary btn-sm px-3"><i class="fa-solid fa-download me-2"></i> Export CSV</a>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3"><div class="card border-0 shadow-sm text-center py-3"><div class="text-muted small">Total Volume (YTD)</div><h3 class="fw-bold text-dark">₹ 14.2 Cr</h3></div></div>
    <div class="col-md-6 col-lg-3"><div class="card border-0 shadow-sm text-center py-3"><div class="text-muted small">Total Applications (YTD)</div><h3 class="fw-bold text-dark">156</h3></div></div>
    <div class="col-md-6 col-lg-3"><div class="card border-0 shadow-sm text-center py-3"><div class="text-muted small">Avg. Processing Time</div><h3 class="fw-bold text-primary">4.2 Days</h3></div></div>
    <div class="col-md-6 col-lg-3"><div class="card border-0 shadow-sm text-center py-3"><div class="text-muted small">Avg. Approval Rate</div><h3 class="fw-bold text-success">69.4%</h3></div></div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 py-3"><h6 class="fw-bold m-0">Loan Volume by Product Type</h6></div>
            <div class="card-body">
                <div class="mb-3"><div class="d-flex justify-content-between small mb-1"><span>Home Loan</span><span>42%</span></div><div class="progress" style="height: 18px;"><div class="progress-bar bg-primary" style="width: 42%;"></div></div></div>
                <div class="mb-3"><div class="d-flex justify-content-between small mb-1"><span>Personal Loan</span><span>28%</span></div><div class="progress" style="height: 18px;"><div class="progress-bar bg-success" style="width: 28%;"></div></div></div>
                <div class="mb-3"><div class="d-flex justify-content-between small mb-1"><span>Commercial</span><span>18%</span></div><div class="progress" style="height: 18px;"><div class="progress-bar bg-warning" style="width: 18%;"></div></div></div>
                <div class="mb-3"><div class="d-flex justify-content-between small mb-1"><span>Education</span><span>8%</span></div><div class="progress" style="height: 18px;"><div class="progress-bar" style="width: 8%; background: #8B5CF6;"></div></div></div>
                <div class="mb-3"><div class="d-flex justify-content-between small mb-1"><span>Vehicle</span><span>4%</span></div><div class="progress" style="height: 18px;"><div class="progress-bar bg-info" style="width: 4%;"></div></div></div>
                <div><div class="d-flex justify-content-between small mb-1"><span>Overdraft</span><span>2%</span></div><div class="progress" style="height: 18px;"><div class="progress-bar bg-danger" style="width: 2%;"></div></div></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 py-3"><h6 class="fw-bold m-0">Monthly Disbursement Trend (₹ Lakhs)</h6></div>
            <div class="card-body">
                <div class="d-flex align-items-end gap-3 justify-content-between" style="height: 220px;">
                    <div class="text-center flex-fill"><div class="bg-primary rounded-top mx-auto" style="width: 36px; height: 108px;"></div><small class="text-muted d-block mt-2">Jan<br>180</small></div>
                    <div class="text-center flex-fill"><div class="bg-primary rounded-top mx-auto" style="width: 36px; height: 132px;"></div><small class="text-muted d-block mt-2">Feb<br>220</small></div>
                    <div class="text-center flex-fill"><div class="bg-primary rounded-top mx-auto" style="width: 36px; height: 186px;"></div><small class="text-muted d-block mt-2">Mar<br>310</small></div>
                    <div class="text-center flex-fill"><div class="bg-primary rounded-top mx-auto" style="width: 36px; height: 168px;"></div><small class="text-muted d-block mt-2">Apr<br>280</small></div>
                    <div class="text-center flex-fill"><div class="bg-primary rounded-top mx-auto" style="width: 36px; height: 210px;"></div><small class="text-muted d-block mt-2">May<br>350</small></div>
                    <div class="text-center flex-fill"><div class="bg-primary rounded-top mx-auto" style="width: 36px; height: 180px;"></div><small class="text-muted d-block mt-2">Jun<br>300</small></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3"><h6 class="fw-bold m-0">Branch-wise Performance Summary</h6></div>
            <div class="card-body p-0">
                <div class="table-responsive border-0">
                    <table class="table align-middle">
                        <thead><tr><th>Branch</th><th>Total Applications</th><th>Approved</th><th>Rejected</th><th>Approval Rate</th><th>Disbursed Volume</th></tr></thead>
                        <tbody>
                            <tr><td class="fw-semibold">Bangalore HQ</td><td>82</td><td><span class="text-success fw-semibold">56</span></td><td><span class="text-danger fw-semibold">8</span></td><td><span class="fw-bold text-success">68.3%</span></td><td class="fw-semibold">₹ 7.8 Cr</td></tr>
                            <tr><td class="fw-semibold">Chennai Branch</td><td>44</td><td><span class="text-success fw-semibold">22</span></td><td><span class="text-danger fw-semibold">3</span></td><td><span class="fw-bold text-success">50.0%</span></td><td class="fw-semibold">₹ 3.6 Cr</td></tr>
                            <tr><td class="fw-semibold">Mumbai Branch</td><td>30</td><td><span class="text-success fw-semibold">11</span></td><td><span class="text-danger fw-semibold">1</span></td><td><span class="fw-bold text-warning">36.7%</span></td><td class="fw-semibold">₹ 2.8 Cr</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
