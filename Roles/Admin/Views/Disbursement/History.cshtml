@{
    ViewData["Title"] = "Disbursement History";
    ViewData["CurrentStep"] = "Disbursement";
}

<div class="row mb-4">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Disbursement Ledger</h1>
        <p class="text-muted mb-0">Complete record of all fund transfer transactions.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

