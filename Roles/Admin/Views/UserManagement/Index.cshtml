@{
    ViewData["Title"] = "User Management";
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">System User Directory</h1>
        <p class="text-muted mb-0">Manage staff accounts, roles and access permissions.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <a href="/UserManagement/Create" class="btn btn-primary px-4 py-2"><i class="fa-solid fa-user-plus me-2"></i> Add New User</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3">
        <div class="row g-3">
            <div class="col-md-5">
                <div class="search-bar d-flex align-items-center bg-light px-3 py-1 rounded-pill" style="border: 1px solid var(--border-color);">
                    <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
                    <input type="text" class="form-control border-0 bg-transparent py-1 shadow-none" placeholder="Search by name, email or role..." style="font-size: 0.85rem;" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select bg-light border-0 py-2 shadow-none" style="font-size: 0.85rem; border-radius: 50rem;">
                    <option value="all">All Roles</option>
                    <option value="admin">Admin</option>
                    <option value="loan officer">Loan Officer</option>
                    <option value="underwriter">Underwriter</option>
                </select>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive border-0">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Branch</th>
                        <th>Status</th>
                        <th>Last Login</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><div class="d-flex align-items-center gap-2"><div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 30px; height: 30px; font-size: 0.75rem; font-weight: 700;">L</div><span class="fw-semibold">Likhith Kumar</span></div></td>
                        <td>likhith.k@locps.in</td>
                        <td><span class="badge bg-primary rounded-pill px-2">Loan Officer</span></td>
                        <td>Bangalore HQ</td>
                        <td><span class="badge-status badge-status-approved">Active</span></td>
                        <td>2026-06-24</td>
                        <td class="text-end"><a href="/UserManagement/Edit/1" class="btn btn-sm btn-light border" title="Edit"><i class="fa-solid fa-pen-to-square text-muted"></i></a></td>
                    </tr>
                    <tr>
                        <td><div class="d-flex align-items-center gap-2"><div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 30px; height: 30px; font-size: 0.75rem; font-weight: 700;">A</div><span class="fw-semibold">Anjali Sharma</span></div></td>
                        <td>anjali.s@locps.in</td>
                        <td><span class="badge bg-info rounded-pill px-2">Underwriter</span></td>
                        <td>Bangalore HQ</td>
                        <td><span class="badge-status badge-status-approved">Active</span></td>
                        <td>2026-06-24</td>
                        <td class="text-end"><a href="/UserManagement/Edit/2" class="btn btn-sm btn-light border" title="Edit"><i class="fa-solid fa-pen-to-square text-muted"></i></a></td>
                    </tr>
                    <tr>
                        <td><div class="d-flex align-items-center gap-2"><div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 30px; height: 30px; font-size: 0.75rem; font-weight: 700;">S</div><span class="fw-semibold">System Administrator</span></div></td>
                        <td>admin@locps.in</td>
                        <td><span class="badge bg-danger rounded-pill px-2">Admin</span></td>
                        <td>All Branches</td>
                        <td><span class="badge-status badge-status-approved">Active</span></td>
                        <td>2026-06-23</td>
                        <td class="text-end"><a href="/UserManagement/Edit/3" class="btn btn-sm btn-light border" title="Edit"><i class="fa-solid fa-pen-to-square text-muted"></i></a></td>
                    </tr>
                    <tr>
                        <td><div class="d-flex align-items-center gap-2"><div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 30px; height: 30px; font-size: 0.75rem; font-weight: 700;">P</div><span class="fw-semibold">Pradeep Menon</span></div></td>
                        <td>pradeep.m@locps.in</td>
                        <td><span class="badge bg-primary rounded-pill px-2">Loan Officer</span></td>
                        <td>Chennai Branch</td>
                        <td><span class="badge-status badge-status-approved">Active</span></td>
                        <td>2026-06-22</td>
                        <td class="text-end"><a href="/UserManagement/Edit/4" class="btn btn-sm btn-light border" title="Edit"><i class="fa-solid fa-pen-to-square text-muted"></i></a></td>
                    </tr>
                    <tr>
                        <td><div class="d-flex align-items-center gap-2"><div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 30px; height: 30px; font-size: 0.75rem; font-weight: 700;">K</div><span class="fw-semibold">Kavitha Rajan</span></div></td>
                        <td>kavitha.r@locps.in</td>
                        <td><span class="badge bg-info rounded-pill px-2">Underwriter</span></td>
                        <td>Mumbai Branch</td>
                        <td><span class="badge-status badge-status-rejected">Inactive</span></td>
                        <td>2026-06-10</td>
                        <td class="text-end"><a href="/UserManagement/Edit/5" class="btn btn-sm btn-light border" title="Edit"><i class="fa-solid fa-pen-to-square text-muted"></i></a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-0 py-3">
        @await Html.PartialAsync("_Pagination")
    </div>
</div>
