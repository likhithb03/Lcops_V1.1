@{
    ViewData["Title"] = "Account Settings";
    var activeRole = Context.Request.Cookies["locps_demo_role"] ?? "officer";
    var initials = "LO"; var fullName = "Likhith Kumar"; var roleLabel = "Loan Officer";
    var email = "likhith.k@locps.in"; var phone = "+91 98765 01234"; var branch = "Bangalore HQ";
    if (activeRole == "customer") { initials = "RK"; fullName = "Rajesh Kumar"; roleLabel = "Portal Customer"; email = "customer@locps.in"; phone = "+91 98765 43210"; branch = "Bangalore Retail"; }
    else if (activeRole == "underwriter") { initials = "UW"; fullName = "Anjali Sharma"; roleLabel = "Senior Underwriter"; email = "anjali.s@locps.in"; phone = "+91 98765 99881"; }
    else if (activeRole == "admin") { initials = "SA"; fullName = "System Administrator"; roleLabel = "Super Admin"; email = "admin@locps.in"; phone = "+91 98765 55667"; branch = "Main Center"; }
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Account Settings</h1>
        <p class="text-muted">Manage your personal profile information, credentials, and notification preferences.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm text-center py-4">
            <div class="card-body">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px; font-weight: 700; font-size: 2rem;">@initials</div>
                <h5 class="fw-bold text-dark mb-1">@fullName</h5>
                <p class="badge bg-light text-secondary border px-3 py-2 fw-semibold mb-3">@roleLabel</p>
                <div class="border-top pt-3 text-start small mt-3">
                    <div class="d-flex justify-content-between mb-2"><span class="text-muted">Account Status:</span><span class="text-success fw-bold">Active</span></div>
                    <div class="d-flex justify-content-between mb-2"><span class="text-muted">Location:</span><span class="fw-semibold text-dark">@branch</span></div>
                    <div class="d-flex justify-content-between"><span class="text-muted">Member Since:</span><span class="fw-semibold text-dark">Jan 2024</span></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3 border-bottom">
                <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-user text-primary me-2"></i> Personal Profile Information</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Full Name</label><p class="form-control-plaintext fw-semibold">@fullName</p></div>
                    <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Email Address</label><p class="form-control-plaintext">@email</p></div>
                    <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Phone Number</label><p class="form-control-plaintext">@phone</p></div>
                    <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Branch Office</label><p class="form-control-plaintext">@branch</p></div>
                </div>
                <div class="mt-4 pt-2">
                    <a href="/Dashboard" class="btn btn-primary px-4" style="border-radius: var(--radius-md);">Save Profile Changes</a>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3 border-bottom">
                <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-lock text-primary me-2"></i> Security & Password Management</h6>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">Password changes are managed by your system administrator. Contact IT support for credential resets.</p>
                <a href="/Dashboard" class="btn btn-dark px-4" style="border-radius: var(--radius-md);">Request Password Change</a>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3 border-bottom">
                <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-bell text-primary me-2"></i> Notification Configurations</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div><h6 class="fw-semibold text-dark mb-0 small">Email Notifications</h6><span class="text-muted small">Receive automatic emails for transaction receipts and application status checks.</span></div>
                    <div class="form-check form-switch mb-0"><input class="form-check-input" type="checkbox" checked disabled /></div>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div><h6 class="fw-semibold text-dark mb-0 small">In-App Alerts</h6><span class="text-muted small">Display updates when scoring rules are complete or applications forward.</span></div>
                    <div class="form-check form-switch mb-0"><input class="form-check-input" type="checkbox" checked disabled /></div>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div><h6 class="fw-semibold text-dark mb-0 small">SMS Reminders</h6><span class="text-muted small">Send text notification warnings for critical underwriter actions.</span></div>
                    <div class="form-check form-switch mb-0"><input class="form-check-input" type="checkbox" disabled /></div>
                </div>
            </div>
        </div>
    </div>
</div>
