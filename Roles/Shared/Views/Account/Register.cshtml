@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LOCPS — Customer Registration</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/theme.css" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--secondary-navy) 0%, #1E3A5F 50%, var(--primary-blue) 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px;
        }
        .register-card { width: 100%; max-width: 680px; border-radius: var(--radius-xl); box-shadow: 0 25px 50px rgba(0,0,0,0.3); border: none; overflow: hidden; }
        .register-header { background: #FFFFFF; border-bottom: 1px solid rgba(226, 232, 240, 0.8); padding: 30px; }
    </style>
</head>
<body>
    <div class="card register-card bg-white">
        <div class="register-header text-center bg-white">
            <h2 class="fw-bold m-0" style="color: var(--secondary-navy);">
                <i class="fa-solid fa-user-plus me-2" style="color: var(--primary-blue);"></i>Create Customer Account
            </h2>
            <p class="text-muted small mb-0 mt-1">Register to view products, apply for loans, and track applications.</p>
        </div>

        <div class="card-body p-4 pt-3">
            <form method="post" action="/Account/Register">
                <input type="hidden" name="role" value="customer" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">First Name <span class="text-danger">*</span></label>
                        <input type="text" name="firstName" class="form-control py-2 shadow-none" placeholder="e.g. Rajesh" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Last Name <span class="text-danger">*</span></label>
                        <input type="text" name="lastName" class="form-control py-2 shadow-none" placeholder="e.g. Kumar" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Email Address <span class="text-danger">*</span></label>
                        <input type="email" name="email" class="form-control py-2 shadow-none" placeholder="e.g. customer@domain.com" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Phone Number <span class="text-danger">*</span></label>
                        <input type="tel" name="phone" class="form-control py-2 shadow-none" placeholder="e.g. +91 98765 43210" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Password <span class="text-danger">*</span></label>
                        <input type="password" name="password" class="form-control py-2 shadow-none" placeholder="Create password" required minlength="6" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Confirm Password <span class="text-danger">*</span></label>
                        <input type="password" name="confirmPassword" class="form-control py-2 shadow-none" placeholder="Confirm password" required minlength="6" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Date of Birth <span class="text-danger">*</span></label>
                        <input type="date" name="dob" class="form-control py-2 shadow-none" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Gender <span class="text-danger">*</span></label>
                        <select name="gender" class="form-select py-2 shadow-none" required>
                            <option value="" disabled selected>Select gender</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="col-12"><hr class="text-muted opacity-25"></div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Employment Type <span class="text-danger">*</span></label>
                        <select name="employment" class="form-select py-2 shadow-none" required>
                            <option value="" disabled selected>Select employment</option>
                            <option value="salaried">Salaried</option>
                            <option value="self-employed">Self-Employed / Business Owner</option>
                            <option value="unemployed">Unemployed</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Monthly Net Income (INR) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted">₹</span>
                            <input type="number" name="income" class="form-control py-2 shadow-none" placeholder="e.g. 75000" required min="0" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">ID Document Type <span class="text-danger">*</span></label>
                        <select name="idType" class="form-select py-2 shadow-none" required>
                            <option value="pan" selected>PAN Card</option>
                            <option value="passport">Passport</option>
                            <option value="aadhaar">Aadhaar Card</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Document ID Number <span class="text-danger">*</span></label>
                        <input type="text" name="idNumber" class="form-control py-2 shadow-none" placeholder="e.g. ABCDE1234F" required />
                    </div>
                </div>
                <div class="mt-4 pt-2 d-flex flex-column gap-2">
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" style="border-radius: var(--radius-md);">
                        <i class="fa-solid fa-user-plus me-2"></i> Register Account
                    </button>
                    <a href="/Account/Login" class="btn btn-light border w-100 py-2" style="border-radius: var(--radius-md);">
                        Back to Login
                    </a>
                </div>
            </form>
        </div>

        <div class="bg-light text-center py-3 border-top">
            <span class="text-muted small">&copy; 2026 LOCPS Banking Portal. Secured with TLS 1.3.</span>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
