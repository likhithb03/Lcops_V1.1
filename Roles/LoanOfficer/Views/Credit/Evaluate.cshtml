@{
    ViewData["Title"] = "Credit Evaluation & Scoring";
    ViewData["CurrentStep"] = "Credit Evaluation";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Credit Evaluation Dashboard</h1>
        <p class="text-muted">Inspect automated credit score analysis, debt indicators, and bureau matches.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm text-center py-4 mb-4">
            <h5 class="fw-bold text-dark mb-3">Bureau Credit Score (CIBIL)</h5>
            <div class="mb-3">
                <h1 class="display-3 fw-extrabold text-success mb-0">785</h1>
                <div class="text-muted">out of 900</div>
            </div>
            <div class="score-gauge-lbl text-success fw-bold">Excellent — Low Risk</div>
            <span class="text-muted small mt-2 d-block">Bureau Pull Timestamp: 2026-06-24 14:30:00</span>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3"><h6 class="fw-bold text-dark m-0">Bureau Score Ranges</h6></div>
            <div class="card-body pt-0" style="font-size: 0.85rem;">
                <div class="d-flex justify-content-between mb-2"><span class="text-muted"><i class="fa-solid fa-circle text-success me-1"></i> Excellent</span><span class="fw-semibold">750 - 900</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="text-muted"><i class="fa-solid fa-circle text-info me-1"></i> Good</span><span class="fw-semibold">700 - 749</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="text-muted"><i class="fa-solid fa-circle text-warning me-1"></i> Fair</span><span class="fw-semibold">600 - 699</span></div>
                <div class="d-flex justify-content-between"><span class="text-muted"><i class="fa-solid fa-circle text-danger me-1"></i> Poor</span><span class="fw-semibold">300 - 599</span></div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3"><h5 class="card-title fw-bold text-dark m-0">Core Risk Metrics Analysis</h5></div>
            <div class="card-body pt-0">
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small"><span class="text-muted fw-semibold">Debt-to-Income Ratio (DTI)</span><span class="fw-bold text-success">32.4% (Optimal)</span></div>
                    <div class="progress" style="height: 8px;"><div class="progress-bar bg-success" style="width: 32.4%;"></div></div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small"><span class="text-muted fw-semibold">Repayment Track Record</span><span class="fw-bold text-success">98.5% On-Time</span></div>
                    <div class="progress" style="height: 8px;"><div class="progress-bar bg-success" style="width: 98.5%;"></div></div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small"><span class="text-muted fw-semibold">Credit Card Utilization Rate</span><span class="fw-bold text-warning">48.2% (Moderate)</span></div>
                    <div class="progress" style="height: 8px;"><div class="progress-bar bg-warning" style="width: 48.2%;"></div></div>
                </div>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3"><h5 class="card-title fw-bold text-dark m-0">Rule Validation Engine</h5></div>
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <div class="p-3 bg-light rounded" style="border-radius: var(--radius-md);">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="fw-semibold small text-dark"><i class="fa-solid fa-calculator me-1"></i> Scoring Engine Evaluation</span>
                            <span class="badge bg-success rounded">Passed</span>
                        </div>
                        <p class="small text-muted mb-0">All credit thresholds verified. Final pricing tier: Tier A eligibility confirmed.</p>
                    </div>
                    <div class="p-3 bg-light rounded" style="border-radius: var(--radius-md);">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="fw-semibold small text-dark"><i class="fa-solid fa-shield-halved me-1"></i> DTI Compliance Rule</span>
                            <span class="badge bg-success rounded">Passed</span>
                        </div>
                        <p class="small text-muted mb-0">Debt-to-Income ratio 32.4% is within safe threshold (&lt; 40%).</p>
                    </div>
                    <div class="p-3 bg-light rounded" style="border-radius: var(--radius-md);">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="fw-semibold small text-dark"><i class="fa-solid fa-chart-line me-1"></i> Repayment History Rule</span>
                            <span class="badge bg-success rounded">Passed</span>
                        </div>
                        <p class="small text-muted mb-0">98.5% on-time repayment record exceeds minimum 95% requirement.</p>
                    </div>
                    <div class="mt-2">
                        <a href="/Dashboard" class="btn btn-success py-2 px-4">Save & Continue <i class="fa-solid fa-arrow-right ms-2"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
