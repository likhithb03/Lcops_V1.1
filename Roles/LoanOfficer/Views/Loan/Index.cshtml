@{
    ViewData["Title"] = "Loan Applications";
    ViewData["CurrentStep"] = "Loan Application";
}

<div class="row mb-4 align-items-center">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark m-0">Loan Applications</h1>
        <p class="text-muted mb-0">Track, review, and manage loan origination cycles.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="card border-0 shadow-sm">
    <div class="card-header border-0 bg-white py-3">
        <div class="row g-3">
            <div class="col-md-5">
                <div class="search-bar d-flex align-items-center bg-light px-3 py-1 rounded-pill" style="border: 1px solid var(--border-color);">
                    <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
                    <input type="text" class="form-control border-0 bg-transparent py-1 shadow-none" placeholder="Search by App ID, Customer, or Product..." style="font-size: 0.85rem;" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select bg-light border-0 py-2 shadow-none" style="font-size: 0.85rem; border-radius: 50rem;">
                    <option value="all">All Application Statuses</option>
                    <option value="pending">Pending</option>
                    <option value="under review">Under Review</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                    <option value="completed">Completed</option>
                </select>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive border-0">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Application ID</th>
                        <th>Customer</th>
                        <th>Loan Product</th>
                        <th>Requested Amount</th>
                        <th>Tenure</th>
                        <th>Workflow Status</th>
                        <th>Applied Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="fw-bold text-dark">LOC-9844-32</span></td>
                        <td><div class="fw-semibold">Rajesh Kumar</div></td>
                        <td>Home Purchase Loan</td>
                        <td>₹ 45,00,000</td>
                        <td>180 Months</td>
                        <td><span class="badge-status badge-status-processing">Under Review</span></td>
                        <td>2026-06-10</td>
                        <td class="text-end"><a href="/Loan/Details/9844" class="btn btn-sm btn-light border"><i class="fa-solid fa-eye text-muted me-1"></i> Details</a> <a href="/Document/Validate/9844" class="btn btn-sm btn-outline-primary" style="font-size: 0.75rem;">Validate Docs</a></td>
                    </tr>
                    <tr>
                        <td><span class="fw-bold text-dark">LOC-7788-12</span></td>
                        <td><div class="fw-semibold">Sunitha Rao</div></td>
                        <td>Personal Express Loan</td>
                        <td>₹ 5,00,000</td>
                        <td>36 Months</td>
                        <td><span class="badge-status badge-status-approved">Approved</span></td>
                        <td>2026-06-12</td>
                        <td class="text-end"><a href="/Loan/Details/7788" class="btn btn-sm btn-light border"><i class="fa-solid fa-eye text-muted me-1"></i> Details</a></td>
                    </tr>
                    <tr>
                        <td><span class="fw-bold text-dark">LOC-4412-99</span></td>
                        <td><div class="fw-semibold">Amit Sharma</div></td>
                        <td>Commercial Equipment Loan</td>
                        <td>₹ 12,00,000</td>
                        <td>60 Months</td>
                        <td><span class="badge-status badge-status-pending">Pending</span></td>
                        <td>2026-06-15</td>
                        <td class="text-end"><a href="/Loan/Details/4412" class="btn btn-sm btn-light border"><i class="fa-solid fa-eye text-muted me-1"></i> Details</a> <a href="/Kyc/Verify/4412" class="btn btn-sm btn-outline-success" style="font-size: 0.75rem;">Verify KYC</a></td>
                    </tr>
                    <tr>
                        <td><span class="fw-bold text-dark">LOC-2231-08</span></td>
                        <td><div class="fw-semibold">Priya Nair</div></td>
                        <td>Personal Express Loan</td>
                        <td>₹ 2,50,000</td>
                        <td>24 Months</td>
                        <td><span class="badge-status badge-status-rejected">Rejected</span></td>
                        <td>2026-06-18</td>
                        <td class="text-end"><a href="/Loan/Details/2231" class="btn btn-sm btn-light border"><i class="fa-solid fa-eye text-muted me-1"></i> Details</a></td>
                    </tr>
                    <tr>
                        <td><span class="fw-bold text-dark">LOC-1155-77</span></td>
                        <td><div class="fw-semibold">Vikram Singh</div></td>
                        <td>Home Purchase Loan</td>
                        <td>₹ 60,00,000</td>
                        <td>240 Months</td>
                        <td><span class="badge-status badge-status-approved">Completed</span></td>
                        <td>2026-06-20</td>
                        <td class="text-end"><a href="/Loan/Details/1155" class="btn btn-sm btn-light border"><i class="fa-solid fa-eye text-muted me-1"></i> Details</a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-0 py-3">
        @await Html.PartialAsync("_Pagination")
    </div>
</div>
