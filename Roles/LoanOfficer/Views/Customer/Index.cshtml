@{
    ViewData["Title"] = "Customer Directory";
    ViewData["CurrentStep"] = "Customer Registration";
}

<div class="row mb-4 align-items-center">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark m-0">Customer Directory</h1>
        <p class="text-muted mb-0">Browse and review registered loan applicants.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="card border-0 shadow-sm">
    <div class="card-header border-0 bg-white py-3">
        <div class="row g-3">
            <div class="col-md-5">
                <div class="search-bar d-flex align-items-center bg-light px-3 py-1 rounded-pill" style="border: 1px solid var(--border-color);">
                    <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
                    <input type="text" class="form-control border-0 bg-transparent py-1 shadow-none" placeholder="Search by name, ID, email, phone..." style="font-size: 0.85rem;" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select bg-light border-0 py-2 shadow-none" style="font-size: 0.85rem; border-radius: 50rem;">
                    <option value="all">All KYC Statuses</option>
                    <option value="verified">Verified</option>
                    <option value="pending">Pending</option>
                    <option value="failed">Failed</option>
                </select>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive border-0">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Customer ID</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone Number</th>
                        <th>KYC Status</th>
                        <th>Registration Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
