                        <td>rajesh.kumar@email.com</td>
                        <td>+91 98765 43210</td>
                        <td><span class="badge-status badge-status-approved">Verified</span></td>
                        <td>2026-06-10</td>
                        <td class="text-end"><a href="/Customer/Details/9011" class="btn btn-sm btn-light border"><i class="fa-solid fa-eye text-muted me-1"></i> View Profile</a></td>
                    </tr>
                    <tr>
