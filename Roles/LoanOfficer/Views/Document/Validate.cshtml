@{
    ViewData["Title"] = "Document Validation";
    ViewData["CurrentStep"] = "Document Validation";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Document Validation Desk</h1>
        <p class="text-muted">Review, accept or reject uploaded documents for Application <strong>LOC-9844-32</strong>.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title fw-bold m-0">Submitted Documents Review Queue</h5>
        <span class="badge bg-success rounded-pill px-3">All Reviewed</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive border-0">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Document Name</th>
                        <th>Category</th>
                        <th>File Type</th>
                        <th>Upload Date</th>
                        <th>Validation Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">PAN_Card_Rajesh_Kumar.pdf</span></td>
                        <td>Identity</td>
                        <td><span class="badge bg-light text-secondary border">PDF</span></td>
                        <td>2026-06-24</td>
                        <td><span class="badge bg-success">Approved</span></td>
                    </tr>
                    <tr>
                        <td><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">Salary_Slip_May_2026.pdf</span></td>
                        <td>Income Proof</td>
                        <td><span class="badge bg-light text-secondary border">PDF</span></td>
                        <td>2026-06-24</td>
                        <td><span class="badge bg-success">Approved</span></td>
                    </tr>
                    <tr>
                        <td><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">Bank_Statement_HDFC_Jan_Jun.pdf</span></td>
                        <td>Bank Statement</td>
                        <td><span class="badge bg-light text-secondary border">PDF</span></td>
                        <td>2026-06-24</td>
                        <td><span class="badge bg-success">Approved</span></td>
                    </tr>
                    <tr>
                        <td><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">Property_Title_Deed_Bangalore.pdf</span></td>
                        <td>Property Docs</td>
                        <td><span class="badge bg-light text-secondary border">PDF</span></td>
                        <td>2026-06-24</td>
                        <td><span class="badge bg-success">Approved</span></td>
                    </tr>
                    <tr>
                        <td><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">Employer_Letter_TechCorp.pdf</span></td>
                        <td>Employer Letter</td>
                        <td><span class="badge bg-light text-secondary border">PDF</span></td>
                        <td>2026-06-24</td>
                        <td><span class="badge bg-warning text-dark">Pending Review</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <span class="text-muted small">All mandatory documents must be accepted before underwriting.</span>
        <a href="/Credit/Evaluate/9844" class="btn btn-success px-4"><i class="fa-solid fa-check-double me-2"></i> Approve All & Forward</a>
    </div>
</div>
