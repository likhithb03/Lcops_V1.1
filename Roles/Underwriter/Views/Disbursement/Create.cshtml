@{
    ViewData["Title"] = "Initiate Disbursement";
    ViewData["CurrentStep"] = "Disbursement";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Initiate Loan Disbursement</h1>
        <p class="text-muted">Configure payment transfer details for sanctioned application <strong>LOC-9844-32</strong>.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3"><h5 class="card-title fw-bold m-0">Payment Transfer Details</h5></div>
            <div class="card-body">
                <ul class="nav nav-pills gap-2 mb-4" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active px-4" data-bs-toggle="pill" data-bs-target="#neft-pane" type="button"><i class="fa-solid fa-building-columns me-2"></i>NEFT</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link px-4" data-bs-toggle="pill" data-bs-target="#imps-pane" type="button"><i class="fa-solid fa-bolt me-2"></i>IMPS</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link px-4" data-bs-toggle="pill" data-bs-target="#cheque-pane" type="button"><i class="fa-solid fa-money-check me-2"></i>Cheque</button>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="neft-pane">
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Account Holder Name</label><input type="text" class="form-control py-2 shadow-none" value="Rajesh Kumar" readonly /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Account Number</label><input type="text" class="form-control py-2 shadow-none" value="HDFC0000198841221" readonly /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold text-muted small">IFSC Code</label><input type="text" class="form-control py-2 shadow-none" value="HDFC0002198" readonly /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Bank Name</label><input type="text" class="form-control py-2 shadow-none" value="HDFC Bank - JP Nagar Branch" readonly /></div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="imps-pane">
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Registered Mobile Number</label><input type="tel" class="form-control py-2 shadow-none" value="+91 98765 43210" readonly /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold text-muted small">MMID Code</label><input type="text" class="form-control py-2 shadow-none" value="9014112" readonly /></div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="cheque-pane">
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Payee Name</label><input type="text" class="form-control py-2 shadow-none" value="Rajesh Kumar" readonly /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold text-muted small">Mailing Address</label><input type="text" class="form-control py-2 shadow-none" value="#45, 2nd Main, JP Nagar, Bangalore - 560078" readonly /></div>
                        </div>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top d-flex gap-2">
                    <a href="/Disbursement/History" class="btn btn-success px-4 py-2"><i class="fa-solid fa-paper-plane me-2"></i> Confirm & Disburse</a>
                    <a href="/Dashboard" class="btn btn-light border px-4 py-2">Cancel</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3"><h6 class="fw-bold m-0">Disbursement Summary</h6></div>
            <div class="card-body pt-0" style="font-size: 0.875rem;">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between"><span class="text-muted">Sanctioned Amount</span><span class="fw-bold text-success">₹ 45,00,000</span></li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between"><span class="text-muted">Processing Fee (0.25%)</span><span class="fw-semibold text-danger">- ₹ 11,250</span></li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between border-top"><span class="fw-bold text-dark">Net Transfer Amount</span><span class="fw-bold text-primary">₹ 44,88,750</span></li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between"><span class="text-muted">First EMI Due</span><span class="fw-semibold">August 1, 2026</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>
